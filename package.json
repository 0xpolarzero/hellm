{
  "name": "hellm",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "vite build && electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run dev\"",
    "hmr": "vite --port 5173",
    "build": "vite build && electrobun build",
    "run": "electrobun run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . --import-plugin --node-plugin --deny-warnings --fix --fix-suggestions",
    "lint:check": "oxlint . --import-plugin --node-plugin --deny-warnings",
    "format": "oxfmt",
    "format:check": "oxfmt --check"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "dependencies": {
    "@mariozechner/mini-lit": "^0.2.0",
    "@mariozechner/pi-agent-core": "^0.64.0",
    "@mariozechner/pi-ai": "^0.64.0",
    "@mariozechner/pi-coding-agent": "^0.64.0",
    "@mariozechner/pi-web-ui": "^0.64.0",
    "electrobun": "1.16.0",
    "lit": "^3.3.1",
    "svelte": "^5.55.1"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/bun": "^1.3.11",
    "concurrently": "^9.2.1",
    "oxlint": "1.59.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3"
  }
}
