{
  "name": "hellm",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "packages/*",
    "test-support"
  ],
  "scripts": {
    "prepare:references": "git submodule update --init --recursive",
    "validate:references": "bun scripts/validate-references.ts",
    "validate:references:strict": "HELLM_REQUIRE_REFERENCES=1 bun test packages/orchestrator/test/reference-guard.test.ts",
    "build": "bun run --filter '@hellm/*' --if-present build",
    "dev": "bun --watch packages/tui/src/main.ts",
    "start": "bun packages/tui/src/main.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "bun run --filter '@hellm/*' typecheck",
    "lint": "oxlint packages --import-plugin --node-plugin --deny-warnings",
    "lint:fix": "oxlint packages --import-plugin --node-plugin --deny-warnings --fix --fix-suggestions",
    "format": "bun run lint:fix",
    "check": "bun run validate:references:strict && bun run lint && bun run typecheck"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "@types/mdx": "2.0.13",
    "@types/react": "19.2.10",
    "@types/react-dom": "19.2.3",
    "ai": "6.0.69",
    "oxlint": "1.59.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "smithers-orchestrator": "0.13.0",
    "typescript": "6.0.2",
    "zod": "4.3.6"
  }
}
